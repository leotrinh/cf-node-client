{
  "env": {
    "node": true,
    "es6": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-console": 1,
    "no-unused-vars": [1, { "argsIgnorePattern": "^_" }],
    "no-undef": 1,
    "no-debugger": 2,
    "semi": 0,
    "comma-dangle": 1,
    "no-unreachable": 1,
    "no-extra-semi": 0
  },
  "overrides": [
    {
      "files": ["examples/**/*.js"],
      "rules": {
        "no-console": 0
      }
    }
  ]
}
